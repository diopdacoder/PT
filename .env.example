# --- Required ---

# Anthropic API key for Claude inference.
ANTHROPIC_API_KEY=

# Postgres connection string. Single quotes recommended if password contains $.
DATABASE_URL=

# Upstash Redis (REST API).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google OAuth credentials. Set redirect URI in Google Cloud Console
# to match GOOGLE_REDIRECT_URI exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-host.example.com/auth/callback

# Public URL the app is reachable at (used to build magic links).
BASE_URL=https://your-host.example.com

# --- Optional ---

# Twilio SMS. Leave blank to print digest URLs to logs instead of sending SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
USER_PHONE=

# Port (most hosts set this automatically).
PORT=3000
